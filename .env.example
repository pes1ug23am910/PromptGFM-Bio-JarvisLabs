# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file with actual credentials

# ================================
# Experiment Tracking
# ================================

# Weights & Biases
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=promptgfm-bio
WANDB_ENTITY=your_username_or_team

# TensorBoard (if using)
TENSORBOARD_LOG_DIR=logs/tensorboard

# ================================
# Data Sources
# ================================

# DisGeNET API (requires free registration at https://www.disgenet.org/signup/)
DISGENET_API_KEY=your_disgenet_api_key_here

# Orphanet (usually doesn't require key)
ORPHANET_API_URL=http://www.orphadata.org/cgi-bin/index.php

# ================================
# Model Paths
# ================================

# Directory for cached models (Transformers, etc.)
TRANSFORMERS_CACHE=~/.cache/huggingface
HF_HOME=~/.cache/huggingface

# Sentence Transformers cache
SENTENCE_TRANSFORMERS_HOME=~/.cache/sentence_transformers

# ================================
# Compute Resources
# ================================

# GPU Configuration
CUDA_VISIBLE_DEVICES=0
PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512

# CPU Threads
OMP_NUM_THREADS=8
MKL_NUM_THREADS=8

# ================================
# Development Settings
# ================================

# Python Environment
PYTHONPATH=.
PYTHONUNBUFFERED=1

# Logging Level
LOG_LEVEL=INFO

# Debug Mode (set to 1 for debugging)
DEBUG=0

# Enable CUDA debugging (slower but helps debug GPU issues)
CUDA_LAUNCH_BLOCKING=0

# ================================
# Cloud Storage (Optional)
# ================================

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=your-bucket-name

# Google Cloud Storage
GOOGLE_APPLICATION_CREDENTIALS=path/to/credentials.json
GCS_BUCKET_NAME=your-gcs-bucket

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=your_connection_string
AZURE_CONTAINER_NAME=your-container-name

# ================================
# Database (Optional)
# ================================

# PostgreSQL (if using for metadata)
DATABASE_URL=postgresql://user:password@localhost:5432/promptgfm

# Redis (if using for caching)
REDIS_URL=redis://localhost:6379/0

# ================================
# API Configuration (Optional)
# ================================

# If deploying as API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# API Security
API_KEY=your_secret_api_key_here
JWT_SECRET=your_jwt_secret_here

# ================================
# Notification (Optional)
# ================================

# Slack notifications for training completion
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password

# ================================
# Research-Specific
# ================================

# Random seed for reproducibility
RANDOM_SEED=42

# Experiment name/ID
EXPERIMENT_NAME=promptgfm-baseline

# ================================
# Notes
# ================================

# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual credentials in .env
# 3. Never commit .env to version control
# 4. Add .env to .gitignore (already done)
# 5. For production, use proper secret management (AWS Secrets Manager, etc.)
